<Window x:Class="ClickerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="CLICKER"
        Width="440"
        SizeToContent="Height"
        MinHeight="640" MinWidth="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        PreviewMouseDown="Window_PreviewMouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#0D0D0D"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#00FF88"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF3355"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#676767"/>
        <SolidColorBrush x:Key="LineBrush" Color="#2A2A2A"/>
        <sys:Double x:Key="ControlFontSize">14</sys:Double>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>

        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="{DynamicResource ControlFontSize}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentButton" TargetType="ToggleButton">
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="{DynamicResource ControlFontSize}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillModeButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgBrush}" CornerRadius="18" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
        <Grid Margin="22,18,22,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="98"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="CLICKER" Foreground="{DynamicResource AccentBrush}"
                               FontFamily="Consolas" FontSize="31" FontWeight="Bold"/>
                    <TextBlock Text="by Killmey" Foreground="{DynamicResource MutedBrush}"
                               FontSize="11" Margin="2,-2,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="7"
                                Padding="8,4" Margin="0,0,6,0">
                            <TextBlock x:Name="MiniMode" Text="ПКМ"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="10" FontWeight="Bold"/>
                        </Border>
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="7"
                                Padding="8,4" Margin="0,0,6,0">
                            <TextBlock x:Name="MiniCps" Text="100 CPS"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="10" FontWeight="Bold"/>
                        </Border>
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="7"
                                Padding="8,4">
                            <TextBlock x:Name="MiniHotkey" Text="Ctrl + Z"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="-" Style="{StaticResource ChromeButton}"
                                Click="Minimize_Click" ToolTip="Згорнути"/>
                        <Button Content="x" Style="{StaticResource ChromeButton}"
                                Click="Close_Click" ToolTip="Закрити"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,7,0,0">
                        <Ellipse x:Name="StatusDot" Width="9" Height="9"
                                 Fill="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="IDLE"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="7,0,0,0"/>
                    </StackPanel>
                    <Border x:Name="RunModeShell"
                            Width="112" Height="28"
                            Background="{DynamicResource LineBrush}"
                            CornerRadius="14"
                            ClipToBounds="True"
                            Margin="0,11,0,0"
                            HorizontalAlignment="Right">
                        <Grid>
                            <Border x:Name="RunModeThumb"
                                    Width="54" Height="24"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="2,0,0,0"
                                    Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="12">
                                <Border.RenderTransform>
                                    <TranslateTransform/>
                                </Border.RenderTransform>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="BtnStayMode" Content="STAY"
                                              Style="{StaticResource PillModeButton}"
                                              Click="RunMode_Click"/>
                                <ToggleButton x:Name="BtnHoldMode" Grid.Column="1" Content="HOLD"
                                              Style="{StaticResource PillModeButton}"
                                              Click="RunMode_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1">
                <Rectangle Height="1" Fill="{DynamicResource LineBrush}" Margin="0,0,0,14"/>

                <TextBlock Text="КНОПКА МИШІ" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <ToggleButton x:Name="BtnLmb" Content="ЛКМ"
                                  Style="{StaticResource SegmentButton}"
                                  Click="MouseButton_Click" Margin="0,0,5,0"/>
                    <ToggleButton x:Name="BtnRmb" Grid.Column="1" Content="ПКМ"
                                  Style="{StaticResource SegmentButton}"
                                  Click="MouseButton_Click" Margin="5,0,0,0"/>
                </Grid>

                <TextBlock Text="КЛІКІВ НА СЕКУНДУ" Style="{StaticResource SectionLabel}"/>
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                        BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                        Padding="0,7" Margin="0,0,0,16">
                    <TextBox x:Name="TxtCps" Text="100"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource AccentBrush}"
                             FontFamily="Consolas" FontSize="34" FontWeight="Bold"
                             HorizontalContentAlignment="Center"
                             CaretBrush="Transparent"
                             LostFocus="TxtCps_LostFocus"
                             KeyDown="TxtCps_KeyDown"/>
                </Border>

                <TextBlock Text="ANTI-DETECT" Style="{StaticResource SectionLabel}"/>
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                        BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                        Padding="14" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="94"/>
                            <ColumnDefinition Width="46"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Рандомізація кліків" Style="{StaticResource PanelTitle}"/>
                            <TextBlock x:Name="TxtAntiSummary"
                                       Text="Вимкнено"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                        <ToggleButton x:Name="BtnAntiToggle" Grid.Column="1"
                                      Content="ВИКЛ"
                                      Style="{StaticResource SegmentButton}"
                                      Click="BtnAntiToggle_Click"
                                      Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Content="⚙"
                                Style="{StaticResource FlatButton}"
                                Click="BtnAntiSettings_Click"
                                Background="{DynamicResource LineBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                FontSize="16" Margin="8,0,0,0"
                                ToolTip="Налаштування anti-detect"/>
                    </Grid>
                </Border>

                <TextBlock Text="ГАРЯЧА КЛАВІША" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="108"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="9"
                            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                            Height="42" Padding="13,0">
                        <TextBlock x:Name="TxtHotkey" Text="Ctrl + Z"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="{DynamicResource ControlFontSize}"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </Border>
                    <Button x:Name="BtnRecord" Grid.Column="1" Content="ЗАПИС"
                            Style="{StaticResource FlatButton}"
                            Click="BtnRecord_Click"
                            Background="{DynamicResource LineBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            Margin="8,0,0,0"/>
                </Grid>

                <TextBlock Text="ВИГЛЯД" Style="{StaticResource SectionLabel}"/>
                <Button Content="КОЛЬОРИ ТА ШРИФТ"
                        Style="{StaticResource FlatButton}"
                        Click="BtnAppearance_Click"
                        Background="{DynamicResource SurfaceBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        Margin="0,0,0,18"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnStart" Content="▶  СТАРТ"
                            Style="{StaticResource FlatButton}"
                            Click="BtnStart_Click"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource BgBrush}"
                            Height="50" Margin="0,0,6,0"/>
                    <Button x:Name="BtnStop" Grid.Column="1" Content="■  СТОП"
                            Style="{StaticResource FlatButton}"
                            Click="BtnStop_Click"
                            Background="{DynamicResource LineBrush}"
                            Foreground="{DynamicResource DangerBrush}"
                            Height="50" Margin="6,0,0,0"/>
                </Grid>
            </StackPanel>

            <TextBlock Grid.Row="2" Text="SendInput  ·  WPF  ·  Windows"
                       Foreground="{DynamicResource MutedBrush}"
                       FontSize="12" HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"/>
        </Grid>
    </Border>
</Window>
