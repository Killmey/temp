<Window x:Class="ClickerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CLICKER"
        Height="600" Width="380"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0D0D0D"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Кнопки головні -->
        <Style x:Key="MainBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton -->
        <Style x:Key="TogBtn" TargetType="ToggleButton">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label мітки секцій -->
        <Style x:Key="SectionLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="20,10,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Background="#111111" Margin="0,0,0,1">
            <StackPanel VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="CLICKER" Foreground="#00FF88"
                           FontFamily="Consolas" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="by Killmey" Foreground="#444444"
                           FontFamily="Consolas" FontSize="10"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                        Orientation="Horizontal" Margin="0,0,15,0">
                <Ellipse x:Name="StatusDot" Width="9" Height="9"
                         Fill="#555555" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="IDLE" Foreground="#555555"
                           FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="─" Style="{StaticResource MainBtn}"
                        Click="Minimize_Click" Background="Transparent"
                        Foreground="#555555" Width="28" Height="28"/>
                <Button Content="✕" Style="{StaticResource MainBtn}"
                        Click="Close_Click" Background="Transparent"
                        Foreground="#555555" Width="28" Height="28"/>
            </StackPanel>
        </Grid>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                      Background="#0D0D0D">
            <StackPanel Margin="0,6,0,10">

                <!-- Роздільник -->
                <Rectangle Height="1" Fill="#1E1E1E" Margin="20,0"/>

                <!-- Кнопка миші -->
                <TextBlock Text="КНОПКА МЫШИ" Style="{StaticResource SectionLbl}"/>
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <ToggleButton x:Name="BtnLmb" Content="ЛКМ"
                                  Style="{StaticResource TogBtn}"
                                  IsChecked="True"
                                  Checked="MouseMode_Changed"
                                  Unchecked="MouseMode_Changed"
                                  Background="#00FF88" Foreground="#0D0D0D"
                                  Margin="0,0,5,0"/>
                    <ToggleButton x:Name="BtnRmb" Grid.Column="1" Content="ПКМ"
                                  Style="{StaticResource TogBtn}"
                                  Checked="MouseMode_Changed"
                                  Unchecked="MouseMode_Changed"
                                  Background="#1A1A1A" Foreground="#555555"
                                  Margin="5,0,0,0"/>
                </Grid>

                <!-- CPS -->
                <TextBlock Text="КЛИКОВ В СЕКУНДУ (CPS)"
                           Style="{StaticResource SectionLbl}"/>
                <Border Background="#1A1A1A" CornerRadius="10"
                        Margin="20,0" Padding="0,8">
                    <TextBox x:Name="TxtCps" Text="100"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#00FF88" FontFamily="Consolas"
                             FontSize="30" FontWeight="Bold"
                             HorizontalContentAlignment="Center"
                             CaretBrush="#00FF88"
                             LostFocus="TxtCps_LostFocus"/>
                </Border>

                <!-- Анти-детект -->
                <TextBlock Text="АНТИВЫЯВЛЕНИЕ" Style="{StaticResource SectionLbl}"/>
                <Border Background="#1A1A1A" CornerRadius="10"
                        Margin="20,0" Padding="14,10">
                    <StackPanel>
                        <CheckBox x:Name="ChkAntiDetect"
                                  Content="ВКЛЮЧИТЬ АНТИ-ДЕТЕКТ"
                                  Foreground="#CCCCCC" FontFamily="Consolas"
                                  FontSize="12" Margin="0,0,0,8"
                                  Checked="AntiDetect_Toggle"
                                  Unchecked="AntiDetect_Toggle"/>

                        <TextBlock Text="Разброс интервала (%)"
                                   Foreground="#555555" FontFamily="Consolas"
                                   FontSize="11" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,6">
                            <Slider x:Name="SldJitter" Minimum="0" Maximum="50"
                                    Value="10" IsSnapToTickEnabled="True"
                                    TickFrequency="1" Margin="0,0,46,0"/>
                            <TextBlock Foreground="#00FF88" FontFamily="Consolas"
                                       FontSize="12" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Text="{Binding ElementName=SldJitter,
                                              Path=Value, StringFormat={}{0}%}"/>
                        </Grid>

                        <TextBlock Text="Шанс микро-паузы (%)"
                                   Foreground="#555555" FontFamily="Consolas"
                                   FontSize="11" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,6">
                            <Slider x:Name="SldBurstChance" Minimum="0" Maximum="30"
                                    Value="2" IsSnapToTickEnabled="True"
                                    TickFrequency="1" Margin="0,0,46,0"/>
                            <TextBlock Foreground="#00FF88" FontFamily="Consolas"
                                       FontSize="12" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Text="{Binding ElementName=SldBurstChance,
                                              Path=Value, StringFormat={}{0}%}"/>
                        </Grid>

                        <TextBlock Text="Разброс удержания (мс)"
                                   Foreground="#555555" FontFamily="Consolas"
                                   FontSize="11" Margin="0,0,0,2"/>
                        <Grid>
                            <Slider x:Name="SldHold" Minimum="0" Maximum="40"
                                    Value="8" IsSnapToTickEnabled="True"
                                    TickFrequency="1" Margin="0,0,56,0"/>
                            <TextBlock Foreground="#00FF88" FontFamily="Consolas"
                                       FontSize="12" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Text="{Binding ElementName=SldHold,
                                              Path=Value, StringFormat={}{0} мс}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Хоткей -->
                <TextBlock Text="ГОРЯЧАЯ КЛАВИША" Style="{StaticResource SectionLbl}"/>
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#1A1A1A" CornerRadius="8"
                            Padding="12,0" Height="40">
                        <TextBlock x:Name="TxtHotkey" Text="Ctrl + Z"
                                   Foreground="#00FF88" FontFamily="Consolas"
                                   FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button x:Name="BtnRecord" Grid.Column="1" Content="ЗАПИСЬ"
                            Style="{StaticResource MainBtn}"
                            Click="BtnRecord_Click"
                            Background="#2A2A2A" Foreground="#CCCCCC"
                            Margin="6,0,0,0"/>
                </Grid>

                <!-- Старт / Стоп -->
                <Grid Margin="20,14,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnStart" Content="▶  СТАРТ"
                            Style="{StaticResource MainBtn}"
                            Click="BtnStart_Click"
                            Background="#00FF88" Foreground="#0D0D0D"
                            Margin="0,0,5,0"/>
                    <Button x:Name="BtnStop" Grid.Column="1" Content="■  СТОП"
                            Style="{StaticResource MainBtn}"
                            Click="BtnStop_Click"
                            Background="#1A1A1A" Foreground="#FF3355"
                            Margin="5,0,0,0"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <TextBlock Grid.Row="2" Text="SendInput  ·  WPF  ·  Windows"
                   Foreground="#333333" FontFamily="Consolas" FontSize="10"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>
